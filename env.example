# =============================================================================
#  .env.example — copy this to .env and fill in real values
#  NEVER commit your actual .env file to GitHub
# =============================================================================

# Neon PostgreSQL connection string (async driver)
# Format: postgresql+asyncpg://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/chatdb?sslmode=require

# JWT Settings
SECRET_KEY=replace-with-a-long-random-string-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
